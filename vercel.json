{
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "realityprivicypolicy.vercel.app"
        }
      ],
      "destination": "/privacy.html"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "realityprivicypolicy.vercel.app"
        }
      ],
      "destination": "/privacy.html",
      "permanent": false
    },
    {
      "source": "/tapasya_web",
      "destination": "/tapasya_web.html",
      "permanent": false
    }
  ]
}
